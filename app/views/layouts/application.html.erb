<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "AiRoute" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <% page_title = content_for(:title) || "AiRoute" %>
    <% page_description = content_for(:description) || "『いつか行きたい』を叶える、デートプランに変わるスポット管理アプリ" %>
    <% page_image = content_for(:og_image) || image_url("ogp.png") %>
    <% page_url = request.original_url %>

    <meta name="description" content="<%= page_description %>">

    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:image" content="<%= page_image %>">
    <meta property="og:url" content="<%= page_url %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="AiRoute">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= page_image %>">

    <%= favicon_link_tag "favicon.ico" %>
    <%= favicon_link_tag "favicon-32x32.png", type: "image/png", sizes: "32x32" %>
    <%= favicon_link_tag "apple-touch-icon.png", rel: "apple-touch-icon", sizes: "180x180" %>

    <%= yield :head %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50">
    <header>
      <%= render 'shared/header' %>
    </header>

    <div
      id="spot-loading-overlay"
      class="fixed inset-0 bg-black/30 backdrop-blur-sm flex items-center justify-center z-40 hidden"
    >
      <div class="bg-white rounded-xl px-4 py-3 text-sm text-gray-700 shadow">
        読み込み中です…
      </div>
    </div>

    <main class="max-w-4xl mx-auto px-4 py-6">
      <% flash.each do |type, message| %>
        <% css_class = case type.to_sym
          when :notice then 'bg-green-100 border-green-500 text-green-900'
          when :alert  then 'bg-red-100 border-red-500 text-red-900'
          else 'bg-gray-100 border-gray-400 text-gray-900'
        end %>

        <div class="mb-4 border-l-4 p-3 rounded <%= css_class %>">
          <p><%= message %></p>
        </div>
      <% end %>

      <%= yield %>
    </main>
    <%= render "shared/footer" %>
  </body>
</html>
